# Пароль для /admin (сервер)
ADMIN_PASSWORD=

# Опционально: секрет подписи Bearer-токена админки (POST /api/admin/upload, POST /api/cases).
# Если не задан — используется производная от ADMIN_PASSWORD (токен переживает рестарт процесса).
# ADMIN_SESSION_SECRET=

# Порт API (Vite proxy и node server/index.mjs). Должен совпадать с тем, что видит Vite в этом же файле.
API_PORT=4000

# Локально: npm run dev — одновременно API и Vite; только фронт без API: npm run dev:vite
# Если EADDRINUSE на этом порту — остановите другой процесс на том же порту (часто Docker), порт в .env не меняйте без необходимости.
#
# Docker (docker compose): кейсы в SQLite server/data/relaylend.db на томе relaylend_cases — пересборка образа их не трогает.
# Не выполняйте «docker compose down -v» на проде (флаг -v удалит том и все загрузки). Первый старт: если есть только cases.json, он импортируется в БД и переименовывается в *.migrated.*.

# Опционально: если фронт на другом домене
# VITE_API_URL=https://api.example.com

# За reverse proxy (nginx/Caddy) для IP в Telegram-уведомлении задайте:
#   proxy_set_header X-Real-IP $remote_addr;
#   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
# Не кэшируйте GET /api/cases (иначе после перезагрузки может открыться старый пустой JSON):
#   location /api/cases { proxy_cache off; add_header Cache-Control "no-store"; ... }

# Telegram — заявки с формы «Начать проект» (POST /api/start).
# Для docker compose на сервере задайте здесь же: compose пробрасывает их в контейнер.
BOT_TOKEN=
TG_ID=

# Альтернативные имена переменных (тоже поддерживаются):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
